{%- if section.blocks.size > 0 -%}
  {%- comment -%}
  ------------------------------------------------------------------------------------------------------------------------
  CSS
  ------------------------------------------------------------------------------------------------------------------------
  {%- endcomment -%}
  <style>
    :root {
      --sticky-announcement-bar-enabled: {%- if section.settings.enable_sticky -%}1{% else %}0{% endif %};
    }

    {%- if section.settings.enable_sticky -%}
      .shopify-section--{{ section.id }} {
        position: sticky;
        top: 0;
        z-index: 20;
      }
    {%- endif -%}

    #shopify-section-{{ section.id }} .announcement-bar__promo-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: clamp(1rem, 3vw, 2.75rem);
    }

    #shopify-section-{{ section.id }} .sale-countdown {
      display: flex;
      align-items: stretch;
      gap: clamp(0.35rem, 1.25vw, 0.85rem);
      font-variant-numeric: tabular-nums;
      line-height: 1;
    }

    #shopify-section-{{ section.id }} .sale-countdown__colon {
      font-weight: 600;
      font-size: clamp(1rem, 2.5vw, 1.5rem);
      align-self: center;
      opacity: 0.8;
      padding-inline: 0.1rem;
    }

    #shopify-section-{{ section.id }} .sale-countdown__unit {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.25rem;
    }

    #shopify-section-{{ section.id }} .sale-countdown__digits {
      font-family: inherit;
      font-weight: 600;
      letter-spacing: 0.06em;
      font-size: clamp(1rem, 2vw, 1.35rem);
    }

    #shopify-section-{{ section.id }} .sale-countdown__label {
      opacity: 0.85;
      font-size: 0.575rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    @media screen and (max-width: 699px) {
      #shopify-section-{{ section.id }} .sale-countdown {
        gap: clamp(0.2rem, 1vw, 0.55rem);
      }
    }
  </style>

  {%- comment -%}
  ------------------------------------------------------------------------------------------------------------------------
  LIQUID
  ------------------------------------------------------------------------------------------------------------------------
  {%- endcomment -%}

  <height-observer variable="announcement-bar">
    <div {% render 'surface', class: 'announcement-bar', background_gradient: section.settings.background_gradient, background: section.settings.background, text_color: section.settings.text_color %}>
      {%- if section.settings.navigation_mode == 'scrolling' -%}
        <marquee-text scrolling-speed="{{ section.settings.scrolling_speed }}" class="announcement-bar__scrolling-list">
          {%- capture content -%}
            {%- for block in section.blocks -%}
              <p class="bold {{ section.settings.text_size }}" {{ block.shopify_attributes }}>
                {%- if block.settings.url != blank -%}
                  <a href="{{ block.settings.url }}">{{ block.settings.text | escape }}</a>
                {%- else -%}
                  {{ block.settings.text | escape }}
                {%- endif -%}
              </p>

              <span class="shape-circle shape--sm"></span>
            {%- endfor -%}
          {%- endcapture -%}

          {%- for i in (1..10) -%}
            <span class="announcement-bar__item" {% unless forloop.first %}aria-hidden="true"{% endunless %}>
              {{- content -}}
            </span>
          {%- endfor -%}
        </marquee-text>
      {%- else -%}
        <div class="container">
          <div class="announcement-bar__wrapper {% if section.blocks.size == 1 %}justify-center{% else %}justify-between{% endif %}">
            {%- assign show_sale_countdown = false -%}
            {%- if section.settings.show_sale_countdown and section.settings.countdown_end != blank and section.settings.navigation_mode != 'scrolling' -%}
              {%- assign show_sale_countdown = true -%}
            {%- endif -%}

            {%- if section.blocks.size > 1 -%}
              <button class="tap-area" is="prev-button" aria-controls="announcement-bar" aria-label="{{ 'general.accessibility.previous' | t }}">
                {%- render 'icon' with 'chevron-left', direction_aware: true -%}
              </button>
            {%- endif -%}

            <div class="{% if show_sale_countdown %}announcement-bar__promo-row {% endif %}w-full {% if section.blocks.size == 1 and show_sale_countdown == false %}text-center{% endif %}">
              <announcement-bar swipeable id="announcement-bar" class="announcement-bar__static-list shrink-0">
                {%- for block in section.blocks -%}
                  <p class="bold {{ section.settings.text_size }} {% unless forloop.first %}reveal-invisible{% endunless %}" {{ block.shopify_attributes }}>
                    {%- if block.settings.url != blank -%}
                      <a href="{{ block.settings.url }}">{{ block.settings.text | escape }}</a>
                    {%- else -%}
                      {{ block.settings.text | escape }}
                    {%- endif -%}
                  </p>
                {%- endfor -%}
              </announcement-bar>

              {%- if show_sale_countdown -%}
                <div
                  id="AnnouncementCountdown-{{ section.id }}"
                  class="sale-countdown"
                  hidden
                  role="timer"
                  aria-live="off"
                  data-end="{{ section.settings.countdown_end | escape }}"
                >
                  <div class="sale-countdown__unit">
                    <span class="sale-countdown__digits" data-countdown-slot="days">00</span>
                    <span class="sale-countdown__label">{{ section.settings.countdown_label_days | escape }}</span>
                  </div>
                  <span class="sale-countdown__colon" aria-hidden="true">:</span>
                  <div class="sale-countdown__unit">
                    <span class="sale-countdown__digits" data-countdown-slot="hours">00</span>
                    <span class="sale-countdown__label">{{ section.settings.countdown_label_hours | escape }}</span>
                  </div>
                  <span class="sale-countdown__colon" aria-hidden="true">:</span>
                  <div class="sale-countdown__unit">
                    <span class="sale-countdown__digits" data-countdown-slot="minutes">00</span>
                    <span class="sale-countdown__label">{{ section.settings.countdown_label_minutes | escape }}</span>
                  </div>
                  <span class="sale-countdown__colon" aria-hidden="true">:</span>
                  <div class="sale-countdown__unit">
                    <span class="sale-countdown__digits" data-countdown-slot="seconds">00</span>
                    <span class="sale-countdown__label">{{ section.settings.countdown_label_seconds | escape }}</span>
                  </div>
                </div>
              {%- endif -%}
            </div>

            {%- if section.blocks.size > 1 -%}
              <button class="tap-area" is="next-button" aria-controls="announcement-bar" aria-label="{{ 'general.accessibility.next' | t }}">
                {%- render 'icon' with 'chevron-right', direction_aware: true -%}
              </button>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </height-observer>
{%- endif -%}

{%- liquid
  assign sale_countdown_js = false
  if section.blocks.size > 0 and section.settings.show_sale_countdown and section.settings.countdown_end != blank and section.settings.navigation_mode != 'scrolling'
    assign sale_countdown_js = true
  endif
-%}

{%- if sale_countdown_js -%}
  <script>
    (function () {
      var root = document.getElementById('AnnouncementCountdown-{{ section.id }}');
      if (!root) return;
      var end = Date.parse(root.getAttribute('data-end'));
      if (!Number.isFinite(end)) return;
      root.removeAttribute('hidden');
      function pad(num, digits) {
        var s = String(Math.max(0, num));
        digits = digits || 2;
        return s.padStart(digits, '0');
      }
      function render() {
        var now = Date.now();
        var remaining = Math.max(0, end - now);
        var totalSecs = Math.floor(remaining / 1000);
        var days = Math.floor(totalSecs / 86400);
        var secs = totalSecs % 86400;
        var hours = Math.floor(secs / 3600);
        secs %= 3600;
        var minutes = Math.floor(secs / 60);
        var seconds = secs % 60;
        var dSlot = root.querySelector('[data-countdown-slot="days"]');
        var hSlot = root.querySelector('[data-countdown-slot="hours"]');
        var mSlot = root.querySelector('[data-countdown-slot="minutes"]');
        var sSlot = root.querySelector('[data-countdown-slot="seconds"]');
        if (dSlot) {
          dSlot.textContent = days >= 100 ? String(days) : pad(days);
        }
        if (hSlot) hSlot.textContent = pad(hours);
        if (mSlot) mSlot.textContent = pad(minutes);
        if (sSlot) sSlot.textContent = pad(seconds);
        if (!remaining && window.clearInterval && root._iv) {
          clearInterval(root._iv);
        }
      }
      render();
      root._iv = setInterval(render, 1000);
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "class": "shopify-section--announcement-bar",
  "tag": "aside",
  "max_blocks": 5,
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Announce something here"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky",
      "label": "Enable sticky bar",
      "default": false
    },
    {
      "type": "select",
      "id": "text_size",
      "label": "Text size",
      "options": [
        {
          "value": "text-xxs",
          "label": "X-Small"
        },
        {
          "value": "text-xs",
          "label": "Small"
        },
        {
          "value": "text-base",
          "label": "Medium"
        },
        {
          "value": "text-lg",
          "label": "Large"
        }
      ],
      "default": "text-xs"
    },
    {
      "type": "select",
      "id": "navigation_mode",
      "label": "Multiple message navigation",
      "options": [
        {
          "value": "arrows",
          "label": "Arrows"
        },
        {
          "value": "scrolling",
          "label": "Auto-scrolling"
        }
      ],
      "default": "arrows"
    },
    {
      "type": "range",
      "id": "scrolling_speed",
      "label": "Scrolling speed",
      "min": 10,
      "max": 30,
      "unit": "s",
      "default": 20
    },
    {
      "type": "header",
      "content": "Countdown promotion"
    },
    {
      "type": "paragraph",
      "content": "Works with “Arrows” message mode only. Dates use ISO format with timezone offset."
    },
    {
      "type": "checkbox",
      "id": "show_sale_countdown",
      "label": "Show countdown next to announcement",
      "default": false
    },
    {
      "type": "text",
      "id": "countdown_end",
      "label": "Sale ends at (ISO 8601)",
      "placeholder": "2026-06-01T23:59:59-05:00",
      "default": ""
    },
    {
      "type": "text",
      "id": "countdown_label_days",
      "label": "Days label",
      "default": "Days"
    },
    {
      "type": "text",
      "id": "countdown_label_hours",
      "label": "Hours label",
      "default": "Hrs"
    },
    {
      "type": "text",
      "id": "countdown_label_minutes",
      "label": "Minutes label",
      "default": "Mins"
    },
    {
      "type": "text",
      "id": "countdown_label_seconds",
      "label": "Seconds label",
      "default": "Secs"
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "Gradient replaces solid colors when set."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text"
    }
  ]
}
{% endschema %}